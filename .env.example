# =============================================================================
# Distributed Property Listing Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials to version control.

# ── PostgreSQL – US Region ────────────────────────────────────────────────────
POSTGRES_US_USER=postgres
POSTGRES_US_PASSWORD=postgres_us_password
POSTGRES_US_DB=properties_us

# ── PostgreSQL – EU Region ────────────────────────────────────────────────────
POSTGRES_EU_USER=postgres
POSTGRES_EU_PASSWORD=postgres_eu_password
POSTGRES_EU_DB=properties_eu

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKER=kafka:29092

# ── Backend – US ──────────────────────────────────────────────────────────────
DATABASE_URL_US=postgresql://postgres:postgres_us_password@db-us:5432/properties_us
REGION_US=us

# ── Backend – EU ──────────────────────────────────────────────────────────────
DATABASE_URL_EU=postgresql://postgres:postgres_eu_password@db-eu:5432/properties_eu
REGION_EU=eu

# ── Application ───────────────────────────────────────────────────────────────
# Port that each backend service listens on (inside the container)
APP_PORT=8000
